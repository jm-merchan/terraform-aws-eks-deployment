              background: rgba(66, 220, 130, 0.15);
              border: 1px solid rgba(66, 220, 130, 0.4);
              color: #42dc82;
              border-radius: 999px;
              padding: 0.4rem 1.1rem;
              font-size: 0.85rem;
              font-weight: 600;
